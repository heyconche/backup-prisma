# ==========================================
# Terraform
# ==========================================
# Ignore local state files (contain secrets and infrastructure data)
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Ignore plugin and module directories
.terraform/
.terraform.lock.hcl

# Ignore variable files with sensitive data
*.tfvars
*.tfvars.json

# ==========================================
# Ansible
# ==========================================
# Ignore inventory files with local IPs and credentials
inventory.ini
hosts.ini

# Ignore Ansible logs and retry files
*.retry
ansible.log

# Ignore sensitive variables (if using Ansible Vault, ignore cleartext files)
group_vars/all.yml.cleartext

# ==========================================
# GCP & Access Keys
# ==========================================
# Ignore Service Account JSON files (NEVER commit these!)
*.json
!example.json # Keep as example if needed

# ==========================================
# System & Editors
# ==========================================
.DS_Store
.idea/
.vscode/
*.swp
*.log
dist/
build/

# Temporary redirection files (e.g., gcloud redirect.yaml)
redirect.yaml